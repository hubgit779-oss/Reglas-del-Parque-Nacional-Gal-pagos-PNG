<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Reglas del Parque Nacional Galápagos</title>
<style>
  :root{
    --bg:#f6fbf9;
    --card:#ffffff;
    --accent:#2b7a6b; /* verde isla */
    --accent-dark:#1f5a48;
    --muted:#7a8b86;
    --danger:#c94a3f;
    --reminder:#6aa0c8; /* azul suave para recordatorios */
    --shadow: 0 6px 18px rgba(20,30,30,0.08);
    font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  }
  body{background:linear-gradient(180deg,#eef9f6 0%,var(--bg) 100%);margin:0;color:#123;line-height:1.35}
  header{padding:28px 20px;text-align:center}
  .title{font-size:20px;font-weight:700;color:var(--accent-dark);letter-spacing:0.6px}
  .subtitle{font-size:13px;color:var(--muted);margin-top:6px}
  .container{max-width:1100px;margin:18px auto;padding:18px}
  .rule-card{display:grid;grid-template-columns:1fr 1fr;gap:18px;background:var(--card);border-radius:12px;padding:16px;margin-bottom:14px;box-shadow:var(--shadow);align-items:start}
  .rule-left,.rule-right{padding:8px}
  .rule-text{font-weight:700;color:var(--accent-dark);margin-bottom:8px}
  .translation{font-size:14px;color:var(--muted);margin-top:8px}
  .consequence{font-weight:600;color:var(--danger);margin-bottom:8px}
  .img-wrap{display:flex;align-items:center;justify-content:center;padding:8px}
  .svg-ill{width:160px;height:110px}
  .reminder-banner{display:flex;gap:10px;align-items:center;padding:10px;border-radius:10px;background:linear-gradient(90deg,rgba(106,160,200,0.12),rgba(43,122,107,0.06));border:1px solid rgba(43,122,107,0.06);margin-bottom:12px}
  .reminder-label{background:var(--reminder);color:white;padding:6px 10px;border-radius:8px;font-weight:700;font-size:13px}
  footer{max-width:1100px;margin:18px auto;padding:18px;text-align:center;color:var(--muted)}
  .qr-panel{display:flex;gap:18px;align-items:center;justify-content:center;margin:18px 0;flex-wrap:wrap}
  .qr-box{background:var(--card);padding:14px;border-radius:12px;box-shadow:var(--shadow);text-align:center}
  .qr-title{font-weight:800;color:var(--accent-dark);margin-bottom:6px}
  .qr-sub{font-size:13px;color:var(--muted);margin-bottom:10px}
  button{background:var(--accent);color:white;border:0;padding:10px 14px;border-radius:8px;cursor:pointer;font-weight:700}
  .small{font-size:13px;color:var(--muted)}
  @media(max-width:880px){
    .rule-card{grid-template-columns:1fr}
    .svg-ill{width:220px;height:140px}
  }
</style>
</head>
<body>
<header>
  <div class="title">REGLAS DEL PARQUE NACIONAL GALÁPAGOS</div>
  <div class="subtitle">GALAPAGOS NATIONAL PARK (GNP) RULES — Ilustrado para visitantes</div>
</header>

<main class="container">

  <!-- QR panel -->
  <section class="qr-panel" aria-label="QR para imprimir">
    <div class="qr-box" id="qrBox">
      <div class="qr-title">REGLAS DEL PARQUE NACIONAL GALAPAGOS</div>
      <div class="qr-sub">GALAPAGOS NATIONAL PARK RULES</div>
      <canvas id="qrCanvas" width="300" height="300" style="background:linear-gradient(180deg,#f8fbfa,#eef6f4);border-radius:8px"></canvas>
      <div style="margin-top:10px">
        <button id="downloadQR">Descargar QR (10×10 cm)</button>
      </div>
      <div class="small" style="margin-top:8px">Abre esta página desde la URL pública donde la publiques y descarga el QR para que apunte a esa dirección.</div>
    </div>
  </section>

  <!-- Rules list -->
  <!-- Each rule: left = regla + cumplimiento image + translation; right = consecuencia + consequence image + translation -->
  
  <!-- Rule 1 -->
  <article class="rule-card" id="r1">
    <div class="rule-left">
      <div class="rule-text">Mantener una distancia de 2 m de la fauna incluidas las cámaras.</div>
      <div class="img-wrap">
        <!-- SVG ilustración cumplimiento -->
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: mantener distancia">
          <rect rx="10" width="200" height="140" fill="#f3fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <circle cx="30" cy="50" r="18" fill="#bfe9d9" stroke="none"/>
            <rect x="60" y="30" width="80" height="40" rx="8" fill="#dff3ee" stroke="none"/>
            <line x1="48" y1="50" x2="60" y2="50" stroke="#1f5a48" stroke-dasharray="4 4"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Mantén 2 m</text>
          </g>
        </svg>
      </div>
      <div class="translation">Keep a distance of 2 meters from wildlife including the cameras.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Acercarse puede estresar, herir o alterar el comportamiento de los animales (abandono de crías, cambios en alimentación o reproducción).</div>
      <div class="img-wrap">
        <!-- SVG ilustración consecuencia -->
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia estrés">
          <rect rx="10" width="200" height="140" fill="#fff5f4"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <circle cx="30" cy="50" r="18" fill="#ffd6d2" stroke="none"/>
            <rect x="60" y="30" width="80" height="40" rx="8" fill="#ffe9e7" stroke="none"/>
            <line x1="48" y1="50" x2="60" y2="50" stroke="#c94a3f" stroke-dasharray="2 3"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Estrés y daño</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Approaching the animals may stress them, injure them, or disrupt their behavior (such as abandonment of young, changes in feeding habits, or changes in reproduction).</div>
    </div>
  </article>

  <!-- Rule 2 -->
  <article class="rule-card" id="r2">
    <div class="rule-left">
      <div class="rule-text">No toque ni alimente la fauna.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: no tocar ni alimentar">
          <rect rx="10" width="200" height="140" fill="#f3fbff"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <path d="M20 60 q20 -30 40 0" fill="#bfe0f0" stroke="none"/>
            <circle cx="120" cy="60" r="18" fill="#bfe9d9" stroke="none"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">No tocar ni alimentar</text>
          </g>
        </svg>
      </div>
      <div class="translation">Do not touch or feed the fauna.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Tocar o alimentar altera la dieta natural, facilita la transmisión de enfermedades y genera dependencia humana; esto reduce la supervivencia a largo plazo de las especies.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia dependencia">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <circle cx="120" cy="60" r="18" fill="#ffd6d2" stroke="none"/>
            <path d="M40 60 q20 -30 40 0" fill="#ffd6d2" stroke="none"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Dependencia y enfermedad</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Handling or feeding animals disrupts their natural diet, facilitates the spread of disease, and creates a dependency on humans; this reduces the species’ long-term survival.</div>
    </div>
  </article>

  <!-- Rule 3 -->
  <article class="rule-card" id="r3">
    <div class="rule-left">
      <div class="rule-text">Toma las fotos sin flash, filmaciones profesionales necesitan autorización; no use drones.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: fotos sin flash">
          <rect rx="10" width="200" height="140" fill="#f7fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <rect x="20" y="30" width="40" height="28" rx="6" fill="#dff3ee"/>
            <circle cx="120" cy="44" r="12" fill="#bfe9d9"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Fotos sin flash</text>
          </g>
        </svg>
      </div>
      <div class="translation">Take pictures without flash. Professional shootings need authorization. Do not use drones.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: El flash y el uso no autorizado de equipos pueden desorientar o estresar a animales; filmaciones o drones sin permiso ponen en riesgo la fauna y la privacidad de áreas protegidas.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia drones">
          <rect rx="10" width="200" height="140" fill="#fff6f8"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <rect x="20" y="30" width="40" height="28" rx="6" fill="#ffd6d2"/>
            <path d="M120 30 l20 -10 l10 10 l-20 10z" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Desorientación y riesgo</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Flash photography and the unauthorized use of equipment can disorient or stress animals; unauthorized filming or the use of drones puts wildlife and the privacy of protected areas at risk.</div>
    </div>
  </article>

  <!-- Rule 4 -->
  <article class="rule-card" id="r4">
    <div class="rule-left">
      <div class="rule-text">No retire elementos del ecosistema.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: no retirar elementos">
          <rect rx="10" width="200" height="140" fill="#f3fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <path d="M30 80 q20 -40 60 -10" fill="#bfe9d9"/>
            <circle cx="140" cy="60" r="10" fill="#dff3ee"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">No retirar elementos</text>
          </g>
        </svg>
      </div>
      <div class="translation">Do not remove elements of the ecosystem.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Quitar plantas, conchas, rocas u otros elementos destruye microhábitats y reduce la biodiversidad local.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia pérdida hábitat">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <path d="M30 80 q20 -40 60 -10" fill="#ffd6d2"/>
            <circle cx="140" cy="60" r="10" fill="#ffe9e7"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Pérdida de microhábitats</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Removing plants, shells, rocks, or other elements destroys microhabitats and reduces local biodiversity.</div>
    </div>
  </article>

  <!-- Rule 5 -->
  <article class="rule-card" id="r5">
    <div class="rule-left">
      <div class="rule-text">Acampe en los sitios designados con autorización previa.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: acampar en sitios designados">
          <rect rx="10" width="200" height="140" fill="#f3fbff"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <path d="M40 70 l20 -30 l20 30z" fill="#dff3ee"/>
            <circle cx="140" cy="60" r="12" fill="#bfe9d9"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Acampe en sitios autorizados</text>
          </g>
        </svg>
      </div>
      <div class="translation">Camp in designated sites prior authorization.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Acampar fuera de zonas autorizadas daña suelos, vegetación y fauna nocturna; aumenta el riesgo de incendios y contaminación.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia acampar fuera">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <path d="M40 70 l20 -30 l20 30z" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Daño a suelos y fauna</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Camping outside authorized areas damages the soil, vegetation, and nocturnal wildlife; it also increases the risk of fires and pollution.</div>
    </div>
  </article>

  <!-- Rule 6 -->
  <article class="rule-card" id="r6">
    <div class="rule-left">
      <div class="rule-text">No fume, no beba alcohol ni haga fogatas.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: no fumar ni alcohol">
          <rect rx="10" width="200" height="140" fill="#f6fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <rect x="20" y="40" width="40" height="18" rx="6" fill="#dff3ee"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">No fumar ni alcohol</text>
          </g>
        </svg>
      </div>
      <div class="translation">Do not smoke, drink alcohol or make campfires.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Fumar o hacer fogatas puede provocar incendios y contaminación; el alcohol puede reducir la conducta responsable del visitante.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia incendios">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <path d="M40 70 q20 -30 40 0" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Riesgo de incendios</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Smoking or building campfires can cause fires and pollution; alcohol can impair visitors’ ability to behave responsibly.</div>
    </div>
  </article>

  <!-- Rule 7 -->
  <article class="rule-card" id="r7">
    <div class="rule-left">
      <div class="rule-text">Usa embarcaciones de pesca vivencial autorizadas.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: embarcaciones autorizadas">
          <rect rx="10" width="200" height="140" fill="#f3fbff"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <path d="M20 80 q40 -30 80 0" fill="#dff3ee"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Embarcaciones autorizadas</text>
          </g>
        </svg>
      </div>
      <div class="translation">Use authorized vivencial fishing boats.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Embarcaciones no autorizadas o prácticas de pesca no reguladas pueden dañar arrecifes, capturar especies protegidas y alterar ecosistemas marinos.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia pesca no regulada">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <path d="M20 80 q40 -30 80 0" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Daño a arrecifes</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Unauthorized vessels or unregulated fishing practices can damage reefs, catch protected species, and disrupt marine ecosystems.</div>
    </div>
  </article>

  <!-- Rule 8 -->
  <article class="rule-card" id="r8">
    <div class="rule-left">
      <div class="rule-text">Camine dentro de los senderos.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: caminar en senderos">
          <rect rx="10" width="200" height="140" fill="#f6fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <path d="M20 80 q40 -40 80 0" fill="#dff3ee"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Caminar en senderos</text>
          </g>
        </svg>
      </div>
      <div class="translation">Walk on marked trails.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Salirse de los senderos provoca erosión, compactación del suelo y daño a plantas endémicas; puede llevar al cierre temporal de rutas para restauración.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia erosión">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <path d="M20 80 q40 -40 80 0" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Erosión y daño</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Hiking off-trail causes erosion, soil compaction, and damage to native plants; it may lead to the temporary closure of trails for restoration.</div>
    </div>
  </article>

  <!-- Rule 9 -->
  <article class="rule-card" id="r9">
    <div class="rule-left">
      <div class="rule-text">No introduzca elementos externos al ecosistema.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: no introducir elementos externos">
          <rect rx="10" width="200" height="140" fill="#f3fbff"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <circle cx="40" cy="60" r="12" fill="#dff3ee"/>
            <circle cx="120" cy="60" r="12" fill="#bfe9d9"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">No introducir elementos</text>
          </g>
        </svg>
      </div>
      <div class="translation">Do not introduce external elements to the ecosystem.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Introducir especies, semillas, alimentos o materiales puede causar invasiones biológicas y desequilibrios ecológicos difíciles de revertir.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia invasiones">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <circle cx="40" cy="60" r="12" fill="#ffd6d2"/>
            <circle cx="120" cy="60" r="12" fill="#ffe9e7"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Invasiones biológicas</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Introducing species, seeds, food, or materials can lead to biological invasions and ecological imbalances that are difficult to reverse.</div>
    </div>
  </article>

  <!-- Rule 10 -->
  <article class="rule-card" id="r10">
    <div class="rule-left">
      <div class="rule-text">Use productos que le protejan del sol amigables con los ecosistemas marinos.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: protector solar amigable">
          <rect rx="10" width="200" height="140" fill="#f6fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
            <rect x="30" y="40" width="30" height="40" rx="6" fill="#dff3ee"/>
            <text x="10" y="120" font-size="10" fill="#1f5a48">Protector solar amigable</text>
          </g>
        </svg>
      </div>
      <div class="translation">Use marine-friendly sun protection products.</div>
    </div>

    <div class="rule-right">
      <div class="consequence">Consecuencia: Productos con químicos nocivos (ciertos bloqueadores solares, repelentes) contaminan el agua y dañan corales y fauna marina.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: consecuencia químicos dañinos">
          <rect rx="10" width="200" height="140" fill="#fff7f3"/>
          <g transform="translate(12,18)" fill="none" stroke="#c94a3f" stroke-width="2">
            <rect x="30" y="40" width="30" height="40" rx="6" fill="#ffd6d2"/>
            <text x="10" y="120" font-size="10" fill="#c94a3f">Daño a corales</text>
          </g>
        </svg>
      </div>
      <div class="translation">Consequence: Products containing harmful chemicals (such as certain sunscreens and insect repellents) pollute the water and harm corals and marine life.</div>
    </div>
  </article>

  <!-- Rule 11 -->
  <article class="rule-card" id="r11">
    <div class="rule-left">
      <div class="rule-text">No use vehículos acuáticos motorizados, submarinos ni turismo aéreo.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: no vehículos motorizados">
          <rect rx="10" width="200" height="140" fill="#f3fbff"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
