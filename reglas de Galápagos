  <article class="rule-card" id="r12">
    <div class="rule-left">
      <div class="rule-text">Use reproductores de sonido con audífonos.</div>
      <div class="img-wrap">
        <svg class="svg-ill" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustración: usar audífonos">
          <rect rx="10" width="200" height="140" fill="#f6fbf9"/>
          <g transform="translate(12,18)" fill="none" stroke="#2b7a6b" stroke-width="2">
